{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Momentum",
  "version": "0.3.3",
  "identifier": "com.momentum-app.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Momentum",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["momentum"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/Weyrd/momentum-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBNUJBNUQ4QTg1N0FGNTgKUldSWXIxZW8yS1ZibWl2Snd0c3VPdDdFSHpyQjQ3K3NmdmQzekVINS9TcXUyNGg2UFllWjZSSHYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "signingIdentity": null
    }
  }
}
